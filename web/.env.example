# Frontend config. Copy to .env.local (dev) or .env.production.local (build) and fill in.

# The issue0x agent API base. Same-origin "/agent" behind a reverse proxy in prod,
# or a full URL to your agent runtime in dev, e.g. http://localhost:8787
VITE_AGENT_API=/agent

# The pons launchpad proxy (served by the agent).
VITE_PONS_API=/agent/pons

# Block explorer base for tx / address / token links.
VITE_EXPLORER=https://robinhoodchain.blockscout.com

# "simulation" shows the pre-launch preview; unset (or any other value) once the
# agent trades live.
VITE_DATA_SOURCE=simulation
