# issue0x agent — copy to .env and fill in. Never commit the real .env.

# ---- Brain ----
# 'mock'      → deterministic, no network, no key. Runs the whole loop offline.
# 'anthropic' → the real Opus 4.8 brain. Requires ANTHROPIC_API_KEY below.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
# The model the trading brain reasons with.
MODEL=claude-opus-4-8
# Hard ceiling on the model's reasoning tokens per decision.
MAX_TOKENS=1024

# ---- Mode ----
# 'paper' → decisions are real, fills are simulated against the data feed. No funds move.
# 'live'  → real on-chain execution. Requires a wired executor + a funded wallet. Do NOT
#           set this until the runtime has been paper-traded and the executor is real.
MODE=paper

# ---- Data + execution venue (Robinhood Chain) ----
# Left blank → the built-in mock feed / paper executor are used. Fill these when the real
# adapters are wired (see src/market.ts and src/executor.ts).
MARKET_DATA_URL=
EXECUTOR_RPC_URL=
WALLET_KEY=

# ---- Radar: real on-chain signals ----
# Set to the official explorer to read REAL Robinhood Chain transfers as radar signals.
# Blank → mock radar. This is safe read-only data (no key, no funds).
BLOCKSCOUT_URL=https://robinhoodchain.blockscout.com
# Curated smart-money / KOL wallets (copy watchlist.example.json → watchlist.json).
WATCHLIST_PATH=watchlist.json

# ---- pons prices/trades (landing ticker + radar Degen column) ----
# The runtime proxies GET /pons/* → www.ponsfamily.com/api/* for real token prices
# and buys. pons rate-limits heavy public access (HTTP 402); a partner key lifts
# that (docs.ponsfamily.com, contact@ponsfamily.com). Point the frontend at this
# proxy with VITE_PONS_API=http://<host>:PORT/pons. Blank → the UI falls back to sim.
PONS_API_KEY=

# ---- Capital + risk ----
START_EQUITY_USDG=50000
MAX_OPEN_POSITIONS=8
MAX_POSITION_PCT=6          # a single position ≤ this % of equity
MAX_LEVERAGE=10
DAILY_LOSS_LIMIT_PCT=8      # kill-switch: pause new opens after a day this far underwater

# ---- Loop ----
TICK_SECONDS=900           # how often the loop wakes (real time). Mock uses sim-time.
PORT=8787                  # the /state server the frontend reads

# ---- Distribution (mirrors web/src/lib/isx.ts; of net realised profit) ----
HOLDER_SHARE=0.70
BURN_SHARE=0.10
